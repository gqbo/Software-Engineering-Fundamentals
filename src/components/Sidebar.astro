---
import { getCollection } from 'astro:content';

interface Props {
  activeSlug?: string;
}

const { activeSlug } = Astro.props;

const categories = (await getCollection('categories'))
  .map((entry) => entry.data)
  .sort((a, b) => a.order - b.order);
---
<nav
  class="hidden md:flex flex-col w-64 fixed left-0 top-0 h-full py-8 bg-[#0d0d0d] border-r border-[#222222] z-40"
  aria-label="Categories"
>
  <div class="px-8 mb-10">
    <h2 class="text-lg font-bold font-mono text-neutral-100 tracking-widest">
      CATEGORÍAS
    </h2>
  </div>

  {categories.length === 0 ? (
    <p class="px-8 font-mono text-xs text-neutral-600">
      Aún no hay categorías.
    </p>
  ) : (
    <ul class="flex flex-col gap-2">
      {categories.map((cat) => {
        const isActive = activeSlug === cat.slug;
        const linkClasses = [
          'flex items-center gap-4 py-3 pl-4 font-mono text-xs duration-150 ease-in-out',
          isActive
            ? 'text-neutral-200 bg-[#111111]'
            : 'text-neutral-500 hover:text-neutral-200 hover:bg-[#111111]',
        ].join(' ');

        return (
          <li>
            <a href={`/category/${cat.slug}`} class={linkClasses}>
              <span class="material-symbols-outlined">{cat.icon}</span>
              <span>{cat.name}</span>
            </a>
          </li>
        );
      })}
    </ul>
  )}
</nav>

---
import { getCollection } from 'astro:content';

interface Props {
  activeSlug?: string;
}

const { activeSlug } = Astro.props;

const categories = (await getCollection('categories'))
  .map((entry) => entry.data)
  .sort((a, b) => a.order - b.order);
---
<nav
  class="hidden md:flex flex-col w-sidebar fixed left-0 top-topbar bottom-0 py-8 z-sidebar bg-bg border-r border-border"
  aria-label="Categories"
>
  <div class="px-8 mb-10">
    <h2 class="font-mono text-h3 text-primary tracking-widest">
      CATEGORÍAS
    </h2>
  </div>

  {categories.length === 0 ? (
    <p class="px-8 font-mono text-ui-micro text-muted-strong">
      Aún no hay categorías.
    </p>
  ) : (
    <ul class="flex flex-col gap-2">
      {categories.map((cat) => {
        const isActive = activeSlug === cat.slug;
        return (
          <li>
            <a
              href={`/category/${cat.slug}`}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'flex items-center gap-4 py-3 pl-4 font-mono text-ui-label transition-colors duration-150 ease-in-out',
                isActive
                  ? 'text-on-surface bg-surface'
                  : 'text-muted hover:text-on-surface hover:bg-surface',
              ]}
            >
              <span class="material-symbols-outlined">{cat.icon}</span>
              <span>{cat.name}</span>
            </a>
          </li>
        );
      })}
    </ul>
  )}
</nav>

---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Card from '../../components/Card.astro';
import DifficultyBadge from '../../components/DifficultyBadge.astro';
import { moduleCategory, moduleSlug } from '../../lib/content';

export async function getStaticPaths() {
  const modules = await getCollection('modules');
  return modules.map(moduleEntry => ({
    params: { slug: moduleSlug(moduleEntry) },
    props: { moduleEntry }
  }));
}

interface Props {
  moduleEntry: CollectionEntry<'modules'>;
}

const { moduleEntry } = Astro.props;
const slug = moduleSlug(moduleEntry);
const categorySlug = moduleCategory(moduleEntry);

const allCategories = await getCollection('categories');
const category = allCategories.find(c => c.id === categorySlug);

if (!category) {
  throw new Error(`Module "${moduleEntry.id}" lives in folder "${categorySlug}" but no matching category file exists at categories/${categorySlug}.md`);
}

const allModules = await getCollection('modules');
const categoryModules = allModules
  .filter(m => moduleCategory(m) === categorySlug)
  .sort((a, b) => a.data.order - b.data.order);

const moduleIndex = categoryModules.findIndex(m => moduleSlug(m) === slug);
const { Content } = await render(moduleEntry);
---

<BaseLayout title={moduleEntry.data.title} activeCategorySlug={category.id}>
  <Breadcrumb items={[moduleEntry.data.title, category.data.name, 'Módulo']} />

  <article class="mb-16">
    <section class="mb-8">
      <div class="mb-4">
        <a href={`/category/${category.id}`} class="text-ui-label text-primary hover:underline font-mono">
          ← {category.data.name}
        </a>
      </div>

      <h1 class="font-mono text-h1 text-primary mb-4">
        {moduleEntry.data.title}
      </h1>

      <div class="flex gap-2 items-center mb-6">
        <DifficultyBadge level={moduleEntry.data.difficulty} size="md" />
      </div>

      <p class="text-body text-muted mb-4">
        {moduleEntry.data.description}
      </p>
    </section>

    <section class="prose max-w-none mb-16">
      <Content />
    </section>

    <Card variant="sunken">
      <div class="space-y-4">
        <div>
          <p class="font-mono text-ui-label text-muted-strong mb-1">Temas clave</p>
          <ul class="space-y-1">
            {moduleEntry.data.topics.map(topic => (
              <li class="text-body text-on-surface-variant text-sm">
                • {topic}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </Card>
  </article>

  <div class="border-t border-border pt-8 flex justify-between">
    <div>
      {moduleIndex > 0 && (
        <>
          <p class="text-ui-micro text-muted-faint mb-2">Anterior en {category.data.name}</p>
          <a
            href={`/module/${moduleSlug(categoryModules[moduleIndex - 1])}`}
            class="font-mono text-ui-label text-primary hover:underline inline-block"
          >
            ← {categoryModules[moduleIndex - 1].data.title}
          </a>
        </>
      )}
    </div>

    <div class="text-right">
      {moduleIndex < categoryModules.length - 1 && (
        <>
          <p class="text-ui-micro text-muted-faint mb-2">Siguiente en {category.data.name}</p>
          <a
            href={`/module/${moduleSlug(categoryModules[moduleIndex + 1])}`}
            class="font-mono text-ui-label text-primary hover:underline inline-block"
          >
            {categoryModules[moduleIndex + 1].data.title} →
          </a>
        </>
      )}
    </div>
  </div>
</BaseLayout>

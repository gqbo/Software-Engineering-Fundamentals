---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Card from '../components/Card.astro';
---
<BaseLayout title="Software Engineering Fundamentals">
  <Breadcrumb items={['Índice', 'Inicio']} />

  <section class="mb-16">
    <h1 class="font-mono text-h1 text-primary mb-4">
      Fundamentos de Ingeniería de Software
    </h1>
    <p class="font-mono text-h3 text-muted">
      Estructura inicializada · contenido pendiente
    </p>
  </section>

  <Card variant="sunken">
    <p class="text-on-surface-variant text-ui-label leading-relaxed">
      Esto es un placeholder para verificar que el shell global funciona.
      El home real se construye en el próximo sprint.
    </p>
  </Card>
</BaseLayout>
